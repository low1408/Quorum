# Must be at least 32 characters. Replace with a private random value.
ENCRYPTION_KEY=replace_with_32_plus_character_secret

# Relative paths are resolved from the repository root.
DATABASE_PATH=./orchestrator.db

# Browser/runtime behavior.
HEADLESS=true
CDP_ENDPOINT=
HUMAN_TYPING=true
CHATGPT_BASE_URL=https://chatgpt.com
LIMIT_DEBATE_RESPONSES=true

# Evaluation and council behavior.
EVALUATOR_PROVIDER=chatgpt
COUNCIL_PROVIDERS=chatgpt,meta,kimi,claude
COUNCIL_MAX_CONCURRENCY=4
COUNCIL_MAX_RETRIES=1
COUNCIL_RETRY_BACKOFF_MS=500
REQUIRE_STRUCTURED_REVIEW_CONTEXT=true

# Test/development only. Enables the internal mock provider outside NODE_ENV=test.
ENABLE_MOCK_PROVIDER=0
